rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null &&
        request.auth.token.email_verified == true &&
        request.auth.token.email in [
          'dharmakrish6@gmail.com',
          'kgmtravelagency@gmail.com'
        ];
    }

    match /buses/{document=**} {
      // Bus listings are public content -- anyone can browse them without
      // signing in (same as the static buses.json fallback), so reads must
      // not require a signed-in session. Only admins can write.
      allow read: if true;
      allow write: if isAdmin();
    }

    match /analytics/{document=**} {
      // Any visitor (anonymous auth) can record a click, but only admins can
      // view aggregated counts or clear them.
      allow read: if isAdmin();
      allow create, update: if request.auth != null;
      allow delete: if isAdmin();
    }
  }
}
