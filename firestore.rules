rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null &&
        request.auth.token.phone_number in [
          '+917200195895',
          '+919742379422'
        ];
    }

    // Signed in with a real account (Google or phone OTP) -- excludes the
    // anonymous sessions used behind the scenes for click tracking.
    function isSignedInUser() {
      return request.auth != null &&
        request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    match /buses/{document=**} {
      allow read: if isSignedInUser();
      allow write: if isAdmin();
    }

    match /analytics/{document=**} {
      // Any visitor (anonymous auth) can record a click, but only admins can
      // view aggregated counts or clear them.
      allow read: if isAdmin();
      allow create, update: if request.auth != null;
      allow delete: if isAdmin();
    }
  }
}
